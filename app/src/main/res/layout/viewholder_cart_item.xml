<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#FFFFFF">

/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- صورة المنتج -->
        <ImageView
            android:id="@+id/imgFood"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/b1"
            android:background="@drawable/rounded_top_corners" />

        <!-- زر الحذف -->
        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/delet_icon"
            app:tint="#999999" />

        <!-- اسم الوجبة -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgFood"
            android:layout_marginStart="12dp"
            android:text="Classic Burger"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000" />


        <TextView
            android:id="@+id/tvSubPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTitle"
            android:layout_toEndOf="@id/imgFood"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="2 × $9.99"
            android:textSize="13sp"
            android:textColor="#888888" />


        <LinearLayout
            android:id="@+id/layoutCounterAndPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvSubPrice"
            android:layout_toEndOf="@id/imgFood"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnMinus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/rounded_background"
                android:padding="6dp"
                android:src="@drawable/outline_check_indeterminate_small_24"
                app:tint="#FF5252" />

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:text="2"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <ImageView
                android:id="@+id/btnPlus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/rounded_background"
                android:padding="6dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FF5252" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$19.98"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FF5252" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>